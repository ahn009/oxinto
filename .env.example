# ============================================
# Smart AI Recommendation System - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# --- Application ---
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# --- Database ---
# Use 'sqlite' for development, 'postgres' for production
DB_TYPE=sqlite
DB_PATH=./data/database.db

# PostgreSQL (production)
DATABASE_URL=postgresql://user:password@localhost:5432/smart_recommendation
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smart_recommendation
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_SSL=false

# --- Session ---
SESSION_TIMEOUT_MINUTES=30
SESSION_CLEANUP_INTERVAL_MINUTES=10

# --- Security ---
API_KEY=your_api_key_here_change_this
JWT_SECRET=your_jwt_secret_here_change_this

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# --- Twilio (WhatsApp) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Meta / Instagram ---
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_PAGE_ACCESS_TOKEN=your_page_access_token
META_VERIFY_TOKEN=your_webhook_verify_token

# --- Logging ---
LOG_LEVEL=info
LOG_FILE=./logs/app.log
